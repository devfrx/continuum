# ===== Server =====
NODE_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
CORS_ORIGIN=http://localhost:5174

# ===== Database =====
DATABASE_URL=postgresql://continuum:continuum@localhost:5432/continuum

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== MinIO / S3 =====
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=continuum
S3_SECRET_KEY=continuum-secret
S3_BUCKET=continuum-files
S3_REGION=us-east-1

# ===== AI Providers =====
# Primary: LM Studio (OpenAI-compatible @ /v1)
AI_PRIMARY_PROVIDER=lmstudio
AI_LMSTUDIO_BASE_URL=http://localhost:1234/v1
AI_LMSTUDIO_API_KEY=lm-studio
AI_LMSTUDIO_CHAT_MODEL=
AI_LMSTUDIO_EMBED_MODEL=

# Secondary / fallback: Ollama (OpenAI-compatible @ /v1)
AI_FALLBACK_PROVIDER=ollama
AI_OLLAMA_BASE_URL=http://localhost:11434/v1
AI_OLLAMA_API_KEY=ollama
AI_OLLAMA_CHAT_MODEL=llama3.2
AI_OLLAMA_EMBED_MODEL=nomic-embed-text

# Embedding vector size (must match the chosen model)
# nomic-embed-text=768, all-minilm=384, mxbai-embed-large=1024
AI_EMBEDDING_DIMENSIONS=768

# ===== Hocuspocus (collaboration) =====
# Note: 1234 is LM Studio's default port — keep this on 1235 to avoid conflict.
HOCUSPOCUS_HOST=0.0.0.0
HOCUSPOCUS_PORT=1235
