{
  "name": "@continuum/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/sensible": "^6.0.2",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.0.1",
    "@hocuspocus/server": "^4.0.0",
    "@continuum/ai-client": "workspace:*",
    "@continuum/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.21",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}